{
  "name": "betano-monitor",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "node scripts/start-expo.mjs",
    "start:clear": "node scripts/start-expo.mjs --clear",
    "start:dev": "node scripts/start-expo.mjs --dev-client",
    "android": "expo run:android",
    "prebuild": "expo prebuild --platform android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "deploy:probe": "powershell -ExecutionPolicy Bypass -File scripts/deploy-betano-probe.ps1",
    "deploy:coleta": "powershell -ExecutionPolicy Bypass -File scripts/deploy-betano-coleta.ps1",
    "deploy:historico": "powershell -ExecutionPolicy Bypass -File scripts/deploy-betano-historico.ps1",
    "build:historico-web": "node scripts/build-historico-template.mjs",
    "build:historico-html": "node scripts/build-historico-template.mjs && node scripts/fill-historico-html.mjs"
  },
  "dependencies": {
    "@notifee/react-native": "9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "2.106.0",
    "babel-preset-expo": "54.0.11",
    "expo": "54.0.35",
    "expo-sqlite": "16.0.10",
    "expo-status-bar": "3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-background-actions": "4.0.1",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@expo/config-plugins": "10.1.2",
    "@types/react": "19.1.10",
    "typescript": "5.9.2"
  }
}
