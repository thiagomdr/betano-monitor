# Painel le o Supabase via web/supabase.config.json (anon key publica).
# Edge Function: placar/lista (cron). HCTG odds: worker VPS (HTML only).

# Supabase (worker VPS + testes locais)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# VPS Lightsail
# LIGHTSAIL_SSH_HOST=
# LIGHTSAIL_SSH_USER=ubuntu
# LIGHTSAIL_SSH_KEY=

# Worker HCTG (opcional)
# HCTG_POLL_SEC=90
# HCTG_POLL_JITTER_SEC=25
# HCTG_MAX_PER_CYCLE=6
# HCTG_MAX_PER_CYCLE_BUSY=14
# HCTG_BUSY_THRESHOLD=15
# HCTG_FETCH_POOL=64
# HCTG_DELAY_MIN_SEC=2
# HCTG_DELAY_MAX_SEC=5
