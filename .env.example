# Painel le o Supabase via web/supabase.config.json (anon key publica).
# Edge Function: placar/lista/mercado +0,5 (cron). HCTG odds: OddsPapi WebSocket (ou HTML legado).

# Supabase (worker + testes locais)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# OddsPapi (Total de Gols via WebSocket — preferido)
# Conta: https://oddspapi.io — WS pode exigir plano B2B
# ODDSPAPI_API_KEY=
# Bookmaker: betano.bet.br
# Teste: cd scripts; node test-oddspapi-ws.mjs
# Worker: cd scripts; node oddspapi-hctg-worker.mjs
# ODDSPAPI_FLUSH_MS=15000

# VPS worker HCTG HTML (legado — so se OddsPapi nao cobrir)
# VPS_SSH_HOST=
# VPS_SSH_USER=root
# VPS_SSH_KEY=
