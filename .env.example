# Painel le o Supabase via web/supabase.config.json (anon key publica).
# Edge Function: placar/lista/mercado +0,5 (cron). HCTG odds: OddsPapi WebSocket (ou HTML legado).

# Supabase (worker + testes locais)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# OddsPapi (Total de Gols — REST polling; WS exige B2B)
# Conta: https://oddspapi.io
# ODDSPAPI_API_KEY=
# ODDSPAPI_BOOKMAKER=betano
# ODDSPAPI_POLL_SEC=90
# ODDSPAPI_MODE=rest
# Teste: cd scripts; node test-oddspapi-ws.mjs
# Worker: cd scripts; node oddspapi-hctg-worker.mjs

# Worker HCTG HTML no PC local (IP residencial da casa) — preferido vs VPS bloqueada
# .\scripts\run-local-hctg-worker.ps1
# .\scripts\run-local-hctg-worker.ps1 -Once
# Smoke IP: cd scripts; npm run local-ip-test
# HCTG_WORKER_SOURCE=local-worker
# HCTG_HTML_SOURCE=html-dom-local
# HCTG_HEADLESS=0
# HCTG_CHROME_PROFILE=C:\Projetos\betano-monitor\.chrome-hctg-profile
# HCTG_POLL_SEC=90
# HCTG_MAX_PER_CYCLE=4
# HCTG_BLOCK_HEAVY=0
# HCTG_LIGHT_CSS=1
