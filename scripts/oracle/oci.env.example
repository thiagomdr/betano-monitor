# Copie para oci.local.env (nao commitar) e preencha com o "Configuration File Preview" da Oracle.
# Identity -> Domains -> Default -> Users -> API Keys -> Add API Key

OCI_USER_OCID=ocid1.user.oc1..aaaa...
OCI_TENANCY_OCID=ocid1.tenancy.oc1..aaaa...
OCI_FINGERPRINT=aa:bb:cc:dd:...
OCI_REGION=sa-saopaulo-1
OCI_KEY_FILE=C:/Users/Controle/.oci/oci_api_key.pem

# Instancia compute (Compute -> Instances -> OCID ou nome)
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..aaaa...
OCI_INSTANCE_OCID=ocid1.instance.oc1.sa-saopaulo-1....aaaa...
# OCI_INSTANCE_NAME=instance-20260707-1952

# SSH (chave da VM, nao da API)
OCI_SSH_KEY_FILE=C:/Users/Controle/Documents/Downloads/ssh-key-2026-07-07.key
OCI_SSH_USER=opc
